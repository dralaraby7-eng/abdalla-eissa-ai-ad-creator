# REQUIRED: Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
# AI Studio injects this automatically when running in AI Studio.
GEMINI_API_KEY="your-gemini-api-key-here"

# OPTIONAL: OpenRouter API Key (enables Claude Opus 4.7, Sonnet 4.6, GPT-4, etc.)
# Get yours at: https://openrouter.ai/keys
# Without this, only Gemini models will be available.
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# OPTIONAL: App URL (auto-injected by AI Studio)
APP_URL="https://your-app-url-here"
